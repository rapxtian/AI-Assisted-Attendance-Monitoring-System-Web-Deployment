# Supabase Configuration
# Go to your Supabase Dashboard -> Project Settings -> API to get these
SUPABASE_URL=https://your-project-id.supabase.co
SUPABASE_KEY=your-supabase-anon-key

# AI / LLM API Keys
# Cohere is used for embeddings (embed-english-v3.0) and the chatbot (command-r-08-2024)
COHERE_API_KEY=your_cohere_api_key
# Groq is used for the Ragas evaluation judge (llama-3.3-70b-versatile)
GROQ_API_KEY=your_groq_api_key
